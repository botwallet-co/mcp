{
  "name": "@botwallet/mcp",
  "version": "0.2.0",
  "description": "MCP server for BotWallet — AI agent payments with FROST threshold signing on Solana",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "botwallet-mcp": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.cjs",
    "prepublishOnly": "npm run build && npm run test",
    "start": "node dist/index.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@scure/bip39": "^1.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "botwallet",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "payments",
    "frost",
    "threshold-signing",
    "x402",
    "solana",
    "usdc",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/botwallet-co/mcp.git"
  },
  "homepage": "https://botwallet.co",
  "bugs": {
    "url": "https://github.com/botwallet-co/mcp/issues"
  },
  "author": "BotWallet <hello@botwallet.co> (https://botwallet.co)",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
